generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  providers Provider[]
}

model Provider {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String   @unique
  description String?
  latitude    Float
  longitude   Float
  photoUrl    String?
  isActive    Boolean  @default(true)

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
}
